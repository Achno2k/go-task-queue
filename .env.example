# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=taskqueue
DB_DSN=host=localhost user=admin password=password dbname=taskqueue port=5432 sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# Server
HTTP_PORT=7070

# Workers
WORKER_COUNT=3
MAX_ATTEMPTS=3

# Lease (seconds): how long a worker can hold a task before the reaper requeues it
LEASE_TIMEOUT=30
REAPER_INTERVAL=10
